---
import { Image } from "astro:assets";
import Layout from "./Layout.astro";
import CTASection from "../components/sections/CTASection.astro";

interface Offering {
  title: string;
  description: string;
}

interface Props {
  title: string;
  headlineMain: string;
  headlineAccent: string;
  heroDescription: string;
  intro: string;
  offerings: Offering[];
  image?: ImageMetadata;
}

const {
  title,
  headlineMain,
  headlineAccent,
  heroDescription,
  intro,
  offerings,
  image,
} = Astro.props;
---

<Layout title={`${title} — Benedikt Ritter`} description={heroDescription}>
  <!-- Hero -->
  <div
    class="relative overflow-hidden"
    style="min-height: 380px; background-color: #1d2b3e;"
  >
    {
      image && (
        <>
          <Image
            src={image}
            alt={title}
            fetchpriority="high"
            style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
          />
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to right, rgba(29,43,62,0.95) 50%, rgba(29,43,62,0.6) 100%);"
          />
        </>
      )
    }
    {
      !image && (
        <div
          class="pointer-events-none absolute inset-0 opacity-10"
          style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 32px 32px;"
        />
      )
    }
    <div class="relative z-10 mx-auto max-w-7xl px-6 py-32">
      <span
        class="font-label text-secondary text-sm font-bold tracking-widest uppercase"
      >
        Services
      </span>
      <h1
        class="mt-3 mb-6 text-4xl font-black tracking-tight text-white md:text-6xl"
      >
        {headlineMain}<br /><span class="text-secondary">{headlineAccent}</span>
      </h1>
      <p class="max-w-xl text-lg leading-relaxed text-white/80">
        {heroDescription}
      </p>
    </div>
  </div>

  <main class="bg-surface pb-0">
    <!-- Intro -->
    <div class="mx-auto max-w-7xl px-6 py-16">
      <p class="text-on-surface-variant max-w-3xl text-lg leading-relaxed">
        {intro}
      </p>
    </div>

    <!-- Offerings -->
    <div class="mx-auto max-w-7xl px-6 pb-20">
      <h2
        class="font-label text-primary mb-8 text-sm font-bold tracking-widest uppercase"
      >
        Areas of expertise
      </h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          offerings.map(item => (
            <div class="bg-surface-container-low p-6">
              <h3 class="text-primary mb-2 font-bold">{item.title}</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
      <p class="text-on-surface-variant mt-8 text-sm">
        Not seeing what you're looking for?{" "}
        <button
          id="service-contact-btn"
          class="text-secondary font-label cursor-pointer font-bold tracking-wide uppercase transition-opacity hover:opacity-70"
        >
          Let's have a chat →
        </button>
      </p>
    </div>
  </main>

  <CTASection />
</Layout>

<script>
  document
    .getElementById("service-contact-btn")
    ?.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("open-contact-modal"));
    });
</script>
