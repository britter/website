---
import { getCollection } from "astro:content";
import { getBlogParams, getPubDate } from "../../utils/params";
import { podcast } from "../../config/data.json";

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .sort((a, b) => getPubDate(b).getTime() - getPubDate(a).getTime())
  .slice(0, 3);
---

<section class="bg-surface py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-12">
      <!-- Podcast -->
      <div class="space-y-8 lg:col-span-4">
        <div class="space-y-3">
          <span
            class="font-label text-secondary text-sm font-bold tracking-widest uppercase"
          >
            Audio Presence
          </span>
          <h2 class="text-primary text-3xl font-black tracking-tight">
            {podcast.name}
          </h2>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            {podcast.description}
          </p>
        </div>
        <a
          href={podcast.url}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary block rounded-lg p-6 transition-opacity hover:opacity-90"
        >
          <div class="flex items-center gap-4">
            <div
              class="bg-primary-container flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-lg"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="text-on-primary h-7 w-7"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </div>
            <div>
              <span
                class="text-secondary-fixed font-mono text-[10px] font-bold uppercase"
              >
                Listen Now
              </span>
              <p class="text-on-primary leading-tight font-bold">
                {podcast.name}
              </p>
              <p class="text-on-primary-container mt-0.5 font-mono text-xs">
                {podcast.handle}
              </p>
            </div>
          </div>
        </a>
      </div>

      <!-- Latest Blog Posts -->
      <div class="space-y-8 lg:col-span-8">
        <div
          class="flex items-end justify-between pb-4"
          style="border-bottom: 2px solid var(--color-surface-container-high);"
        >
          <h2 class="text-primary text-3xl font-black tracking-tight">
            Latest Insights
          </h2>
          <a
            href="/blog"
            class="font-label text-secondary flex items-center gap-2 text-xs font-bold tracking-widest uppercase transition-all hover:gap-3"
          >
            View Archive →
          </a>
        </div>

        <div>
          {
            recentPosts.map(post => {
              const params = getBlogParams(post);
              const url = `/blog/${params.path}`;
              const firstTopic = post.data.topics?.[0];
              return (
                <a
                  href={url}
                  class="group block py-7"
                  style="border-bottom: 1px solid var(--color-surface-container-high);"
                >
                  <div class="flex items-center justify-between gap-4">
                    <div class="space-y-2">
                      <div class="text-on-surface-variant flex items-center gap-3 font-mono text-[10px] uppercase">
                        <span>
                          {getPubDate(post).toLocaleDateString("en-US", {
                            month: "short",
                            day: "numeric",
                            year: "numeric",
                          })}
                        </span>
                        {firstTopic && (
                          <>
                            <span class="bg-outline-variant h-1 w-1 rounded-full" />
                            <span class="text-secondary font-bold">
                              {firstTopic}
                            </span>
                          </>
                        )}
                      </div>
                      <h3 class="text-on-surface group-hover:text-secondary text-xl font-bold transition-colors">
                        {post.data.title}
                      </h3>
                    </div>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="text-on-surface-variant h-5 w-5 flex-shrink-0 translate-x-2 opacity-0 transition-all group-hover:translate-x-0 group-hover:opacity-100"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>
