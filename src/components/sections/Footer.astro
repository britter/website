---
import { nav as navLinks } from "../../config/data.json";

const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-container-low">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="space-y-3">
        <div
          class="text-on-surface font-sans text-lg font-black tracking-tighter"
        >
          Benedikt Ritter
        </div>
        <p
          id="footer-copyright"
          class="text-outline font-mono text-xs leading-relaxed tracking-wide"
        >
          © {currentYear} Benedikt Ritter.<br />Built with Nix & Precision.
        </p>
      </div>

      <!-- Connect -->
      <div class="space-y-3">
        <h5
          class="font-label text-outline text-[10px] font-bold tracking-widest uppercase"
        >
          Connect
        </h5>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/britter"
              target="_blank"
              rel="noopener noreferrer"
              class="text-on-surface-variant hover:text-secondary font-mono text-xs transition-colors"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://chaos.social/@britter"
              target="_blank"
              rel="noopener noreferrer"
              class="text-on-surface-variant hover:text-secondary font-mono text-xs transition-colors"
            >
              Mastodon
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/benedikt-ritter-83847b84/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-on-surface-variant hover:text-secondary font-mono text-xs transition-colors"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="/feed.xml"
              class="text-on-surface-variant hover:text-secondary font-mono text-xs transition-colors"
            >
              RSS Feed
            </a>
          </li>
        </ul>
      </div>

      <!-- Navigate -->
      <div class="space-y-3">
        <h5
          class="font-label text-outline text-[10px] font-bold tracking-widest uppercase"
        >
          Navigate
        </h5>
        <ul class="space-y-2">
          {
            navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="text-on-surface-variant hover:text-secondary font-mono text-xs transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal -->
      <div class="space-y-3">
        <h5
          class="font-label text-outline text-[10px] font-bold tracking-widest uppercase"
        >
          Legal
        </h5>
        <ul class="space-y-2">
          <li>
            <a
              href="/terms"
              class="text-on-surface-variant hover:text-secondary font-mono text-xs transition-colors"
            >
              Terms & Conditions
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>
